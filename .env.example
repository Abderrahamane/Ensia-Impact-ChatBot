# Core
TELEGRAM_BOT_TOKEN=
ENSIA_GENERATION_BACKEND=extractive
# Valid values: extractive, groq, gemini, hf_lora
ENSIA_ALLOW_EXTRACTIVE_FALLBACK=1

# Retrieval
ENSIA_COLLECTION=ensia_impact
ENSIA_RAG_TOP_K=5
ENSIA_RAG_MIN_SIM=0.35
ENSIA_RAG_MAX_CONTEXT_CHARS=3500
ENSIA_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Gemini
GOOGLE_API_KEY=
ENSIA_GEMINI_MODEL=models/gemini-2.0-flash-001
ENSIA_GEMINI_FALLBACK_MODELS=models/gemini-2.0-flash-lite-001,models/gemini-2.0-flash-lite
ENSIA_GENERATION_TIMEOUT_S=35
ENSIA_GENERATION_RETRY_COUNT=2
ENSIA_GENERATION_RETRY_BACKOFF_S=1.5

# Hugging Face LoRA backend
# Set ENSIA_GENERATION_BACKEND=hf_lora to enable
ENSIA_HF_BASE_MODEL=Qwen/Qwen2.5-7B-Instruct
ENSIA_HF_LORA_ADAPTER_DIR=
ENSIA_HF_MAX_NEW_TOKENS=220
ENSIA_HF_TEMPERATURE=0.2

# Local backend aliases (Ollama/local gateway)
ENSIA_LOCAL_BASE_URL=http://127.0.0.1:11434
ENSIA_LOCAL_API_KEY=
ENSIA_LOCAL_MODEL_1=qwen2.5:1.5b-instruct
ENSIA_LOCAL_MODEL_2=phi3:mini

# Confidence gate before generation
ENSIA_GENERATION_MIN_TOP_SCORE=0.42
ENSIA_GENERATION_MIN_AVG_SCORE=0.35

# Bot hardening
ENSIA_BOT_COOLDOWN_SECONDS=3
ENSIA_BOT_RATE_LIMIT_PER_MINUTE=8
ENSIA_BOT_TIMEOUT_SECONDS=45
ENSIA_BOT_RETRY_COUNT=2
ENSIA_SOURCES_DEFAULT_ON=1
ENSIA_ADMIN_USER_IDS=

# Ops
ENSIA_LOG_LEVEL=INFO
ENSIA_BACKUP_RETENTION_DAYS=7

GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE 
ENSIA_GROQ_MODEL=llama-3.3-70b-versatile
